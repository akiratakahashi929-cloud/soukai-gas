function renderCoverPage(body) {
  for (var i = 0; i < 8; i++) addBlankLine(body);
  addH1(body, '第 39 回 定 期 総 会');
  addBlankLine(body);
  addText(body, '埼 玉 県 ト ラ ッ ク 協 会', 'center');
  addText(body, '所 沢 支 部 青 年 部 会', 'center');
  for (var i = 0; i < 4; i++) addBlankLine(body);
  addText(body, '令和 ７年  ５月１０日（土）', 'center');
  addText(body, '於　角家', 'center');
  addText(body, '１６時００分　開会', 'center');
}

function renderAgenda(body) {
  addH1(body, '総　会　次　第');
  addBlankLine(body);
  var items = [
    '１．開会の辞',
    '２．会長挨拶',
    '３．来賓祝辞及び紹介',
    '４．議長選任',
