function renderBylaws1(body) {
  addH2(body, '埼玉県トラック協会所沢支部青年部会');
  addText(body, '', 'center');
  addH2(body, '会　　　則');
  addBlankLine(body);
  var articles = [
    ['（名称）','第１条','埼玉県トラック協会所沢支部青年部会と称するものとする。以下本会という。'],
    ['（目的）','第２条','本会は、トラック事業の後継者及び幹部社員の育成と親睦をはかり、健全なる事業の発展に努め、トラック事業及び支部発展のために寄与するものである。'],
    ['（会員）','第３条','本会は埼玉県トラック協会所沢支部の事業所（原則として支部在籍６ヶ月以上）の後継者又は事業所責任者によって組織し運営する。入会は各事業所１名以上若干名とする。又本会の趣旨に賛同する法人又は個人を協賛会員とする事が出来る。'],
    ['（限定）','第４条','会員の年齢は、満２０歳より原則５０歳までとする。'],
    ['（会費）','第５条','会費は月々２千円とする。但し各社２人目以降は半額とする。その他に必要に応じ特別会費を徴収する事が出来る。'],
    ['（役員）','第６条','本会は次の役を置く。\n（１）会長１名　　（２）副会長若干名\n（３）県青年部担当１名　　（４）委員長若干名\n（５）事務局１名　　（６）会計１名\n（７）会計監査１名'],
    ['（役員の選任）','第７条','１，本会の会長は、総会において３分の２以上の多数をもって選任される。\n２，会長以下役員は、会長が指名する。'],
    ['（役員の任期）','第８条','１，役員の任期は２年とする。但し再任を妨げない。\n２，補充された役員は前任者の残任期間とする。\n３，役員は任期満了でも後任者の就任があるまでは、その職務を行うものとする。'],
    ['（顧問）','第９条','１，本会に顧問を若干名置く事が出来る。\n２，顧問は役員会において選任する。\n３，顧問は会長の要請により各議会に出席し本会の重要事項について意見を述べる事が出来る。'],
    ['（会議）','第１０条','定例会議は３ヶ月に１回とする。']
  ];
  articles.forEach(function(a) {
    addH3(body, a[0]);
    addText(body, a[1] + '　' + a[2]);
  });
}

function renderBylaws2(body) {
  var articles = [
    ['（総会）','第１１条','１，通常総会は年１回とし、下記項目を議題とする。\n　（１）事業報告及び会計収支決算報告\n　（２）事業案及び予算案の審議\n　（３）本会則の変更\n　（４）その他の重要事項\n２，臨時総会は役員会において必要と認めた時に召集する。'],
    ['（召集）','第１２条','総会は会長が召集する。会長が欠席の場合は会長の要請により副会長が召集する。'],
    ['（定例会）','第１３条','定例会はその都度、議題を持ちよって討議する。'],
    ['（役員会）','第１４条','役員会は必要に応じ会長が召集し、次の事項を審議する。\n　（１）総会に提出すべき議案\n　（２）重要事項及び事業計画\n　（３）総会を招集する緊急議案\n　（４）その他会長が必要と認めた事項'],
    ['（議決）','第１５条','議決は過半数以上の会員の出席により運営される。また、出席会員の過半数の賛同を得て議決する。'],
    ['（年度）','第１６条','本会の会計年度は４月１日に始まり３月３１日に終わる。'],
    ['（除名）','第１７条','1，秩序を乱し本会の目的に反する行為を行なった者に対しては、役員会に於いて除名する。\n２，通年を通して、青年部活動に対して参加意欲に欠く者に対しては、役員会に於いて除名する事が出来る。'],
    ['（脱会）','第１８条','１，会員が移動その他の事由により脱退しようとする時はその旨を会長に届け出て役員会の承認を得るものとする。\n２，前項の場合未納の会費は完納しなければならない。但し既納の会費は払い戻さない。'],
    ['（委員会）','第１９条','本会には委員会を置く事が出来る。'],
    ['（会則の成立）','第２０条','本会の会則は総会の３分の２以上の決をもって成立する。'],
    ['（その他）','第２１条','本規約に定めない事項については、総会において決議するものとする。'],
    ['','第２２条','本規約は、令和６年４月１日より実施する。']
  ];
  articles.forEach(function(a) {
    if (a[0]) addH3(body, a[0]);
    addText(body, a[1] + '　' + a[2]);
  });
}

function renderCondolenceRules(body) {
  addH2(body, '埼玉県トラック協会所沢支部青年部会');
  addH2(body, '慶弔規定');
  addBlankLine(body);
  addH3(body, '第１条（目的）');
