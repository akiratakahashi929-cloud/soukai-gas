// ============================================================
// ユーティリティ関数
// ============================================================
function addPageBreak(body) {
  body.appendPageBreak();
}

function addH1(body, text) {
  var p = body.appendParagraph(text);
  p.setHeading(DocumentApp.ParagraphHeading.HEADING1);
  p.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
  p.setFontFamily(FONT_FAMILY).setFontSize(FONT_H1).setBold(true);
  return p;
}

function addH2(body, text) {
  var p = body.appendParagraph(text);
  p.setHeading(DocumentApp.ParagraphHeading.HEADING2);
  p.setFontFamily(FONT_FAMILY).setFontSize(FONT_H2).setBold(true);
  return p;
}

function addH3(body, text) {
  var p = body.appendParagraph(text);
  p.setHeading(DocumentApp.ParagraphHeading.HEADING3);
  p.setFontFamily(FONT_FAMILY).setFontSize(FONT_H3).setBold(true);
  return p;
}

function addText(body, text, align) {
  var p = body.appendParagraph(text);
  p.setFontFamily(FONT_FAMILY).setFontSize(FONT_BODY);
  if (align === 'center') p.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
  if (align === 'right') p.setAlignment(DocumentApp.HorizontalAlignment.RIGHT);
  return p;
}

function addBlankLine(body) {
  var p = body.appendParagraph('');
  p.setFontSize(FONT_BODY);
  return p;
}

function createStyledTable(body, headers, rows) {
  var allData = [headers].concat(rows);
  var table = body.appendTable(allData);
  table.setBorderWidth(0.5);
  // Header row
  var headerRow = table.getRow(0);
  for (var c = 0; c < headerRow.getNumCells(); c++) {
    var cell = headerRow.getCell(c);
    cell.setBackgroundColor(COLOR_HEADER_BG);
    var cp = cell.getChild(0).asParagraph();
    cp.setFontFamily(FONT_FAMILY).setFontSize(FONT_TABLE).setBold(true);
    cp.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
  }
  // Data rows
  for (var r = 1; r < table.getNumRows(); r++) {
    var row = table.getRow(r);
    for (var c = 0; c < row.getNumCells(); c++) {
      var cell = row.getCell(c);
      var cp = cell.getChild(0).asParagraph();
      cp.setFontFamily(FONT_FAMILY).setFontSize(FONT_TABLE).setBold(false);
    }
  }
  return table;
}

function fmtNum(n) {
  if (n === '' || n === null || n === undefined) return '';
  var num = Number(n);
  if (isNaN(num)) return String(n);
  return num.toLocaleString('ja-JP');
}
